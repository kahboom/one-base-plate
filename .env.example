# Supabase — from Project Settings → API (same URL for both key types).
# VITE_SUPABASE_ANON_KEY: use the dashboard "publishable" key (sb_publishable_…)
# or the legacy "anon" key; both work with createClient. Never put the secret /
# service_role key here (Vite exposes VITE_* to the browser).
# Cloud sync expects RLS: run supabase/migrations/001_households.sql then
# 002_invites.sql in the SQL editor (or via CLI) on your project.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key-here
OPENAI_API_KEY=your-openai-api-key-here
