        ],
        "ingredientsText": "200g plain yogurt\nJuice and zest of 1 lime\nSmall bunch cilantro, chopped",
        "directions": "1. Mix yogurt, lime juice, and lime zest in a bowl.\n2. Finely chop cilantro and stir in.\n3. Season with a pinch of salt. Serve cold.",
        "defaultPrep": "Stir yogurt, lime, and cilantro together.",
        "prepTimeMinutes": 5,
        "servings": "4"
      },
      {
        "id": "rec-pizza-dough",
        "name": "Basic pizza dough",
        "recipeType": "component",
        "tags": ["batch-friendly", "freezer-friendly", "pizza"],
        "components": [
          { "id": "mc-rpd-1", "ingredientId": "ing-flour", "role": "carb", "quantity": "500g" },
          { "id": "mc-rpd-2", "ingredientId": "ing-yeast", "role": "carb", "quantity": "7g sachet" },
          { "id": "mc-rpd-3", "ingredientId": "ing-olive-oil", "role": "sauce", "quantity": "2 tbsp" },
          { "id": "mc-rpd-4", "ingredientId": "ing-sugar", "role": "sauce", "quantity": "1 tsp" }
        ],
        "ingredientsText": "500g flour\n7g sachet yeast\n2 tbsp olive oil\n1 tsp sugar\n1 tsp salt\n325ml warm water",
        "directions": "1. Mix flour, yeast, sugar, and salt in a large bowl.\n2. Add warm water and olive oil; stir until a shaggy dough forms.\n3. Knead on a floured surface for 8-10 minutes until smooth and elastic.\n4. Place in an oiled bowl, cover, and let rise 1 hour until doubled.\n5. Punch down and divide into 2-3 balls. Ready to stretch and top.",
        "defaultPrep": "Mix, knead, and let rise.",
        "notes": "Dough freezes well. Wrap balls individually in cling film for the freezer.",
        "prepTimeMinutes": 20,
        "cookTimeMinutes": 60,
        "servings": "2-3 pizzas"
      },
      {
        "id": "rec-pizza-sauce",
        "name": "Quick pizza sauce",
        "recipeType": "sauce",
        "tags": ["quick", "batch-friendly", "freezer-friendly", "pizza"],
        "components": [
          { "id": "mc-rps-1", "ingredientId": "ing-tinned-tomatoes", "role": "sauce", "quantity": "1 tin" },
          { "id": "mc-rps-2", "ingredientId": "ing-garlic", "role": "veg", "quantity": "2 cloves" },
          { "id": "mc-rps-3", "ingredientId": "ing-oregano", "role": "sauce", "quantity": "1 tsp" },
          { "id": "mc-rps-4", "ingredientId": "ing-olive-oil", "role": "sauce", "quantity": "1 tbsp" }
        ],
        "ingredientsText": "1 tin tinned tomatoes\n2 cloves garlic, minced\n1 tsp oregano\n1 tbsp olive oil\nPinch of salt and sugar",
        "directions": "1. Heat olive oil in a small pan over medium heat.\n2. Add minced garlic, cook 30 seconds.\n3. Add tinned tomatoes, oregano, and a pinch each of salt and sugar.\n4. Simmer 10-15 minutes, stirring occasionally, until thickened.\n5. Blend or mash to desired smoothness.",
        "defaultPrep": "Simmer tomatoes with garlic and oregano.",
        "prepTimeMinutes": 5,
        "cookTimeMinutes": 15,
        "servings": "2-3 pizzas"
      },
      {
        "id": "rec-tray-pizza",
        "name": "Simple tray pizza",
        "recipeType": "whole-meal",
        "tags": ["batch-friendly", "pizza"],
        "components": [
          { "id": "mc-rtp-1", "ingredientId": "ing-flour", "role": "carb", "quantity": "500g" },
          { "id": "mc-rtp-2", "ingredientId": "ing-tinned-tomatoes", "role": "sauce", "quantity": "1 tin" },
          { "id": "mc-rtp-3", "ingredientId": "ing-mozzarella", "role": "topping", "quantity": "250g" },
          { "id": "mc-rtp-4", "ingredientId": "ing-peppers", "role": "veg", "quantity": "1" },
          { "id": "mc-rtp-5", "ingredientId": "ing-basil", "role": "topping", "quantity": "few leaves" }
        ],
        "ingredientsText": "1 batch pizza dough (or 500g flour + 7g yeast + oil/sugar/salt/water)\n1 tin tomatoes (or batch of pizza sauce)\n250g mozzarella, sliced or torn\n1 pepper, sliced\nFresh basil leaves",
        "directions": "1. Preheat oven to 220°C / 425°F.\n2. Stretch dough to fit an oiled baking tray.\n3. Spread pizza sauce evenly over the dough.\n4. Scatter mozzarella and sliced peppers over the top.\n5. Bake 15-20 minutes until crust is golden and cheese is bubbling.\n6. Top with fresh basil leaves. Slice and serve.",
        "defaultPrep": "Stretch dough on tray, top, and bake.",
        "notes": "Use store-bought dough or a flatbread base for a faster shortcut version.",
        "prepTimeMinutes": 15,
        "cookTimeMinutes": 20,
        "servings": "4"
      },
      {
