      {
        "id": "rec-taco-chicken",
        "name": "Grilled taco chicken",
        "recipeType": "component",
        "tags": ["batch-friendly", "freezer-friendly", "taco"],
        "components": [
          { "id": "mc-rtc-1", "ingredientId": "ing-chicken", "role": "protein", "quantity": "600g" },
          { "id": "mc-rtc-2", "ingredientId": "ing-olive-oil", "role": "sauce", "quantity": "2 tbsp" },
          { "id": "mc-rtc-3", "ingredientId": "ing-cumin", "role": "sauce", "quantity": "1 tsp" },
          { "id": "mc-rtc-4", "ingredientId": "ing-chili-powder", "role": "sauce", "quantity": "1 tsp" },
          { "id": "mc-rtc-5", "ingredientId": "ing-garlic-powder", "role": "sauce", "quantity": "0.5 tsp" },
          { "id": "mc-rtc-6", "ingredientId": "ing-lime", "role": "sauce", "quantity": "1" }
        ],
        "ingredientsText": "600g chicken breast\n2 tbsp olive oil\n1 tsp cumin\n1 tsp chili powder\n0.5 tsp garlic powder\nJuice of 1 lime",
        "directions": "1. Slice chicken breast into thin strips or flatten to even thickness.\n2. Mix olive oil, cumin, chili powder, garlic powder, and lime juice in a bowl.\n3. Toss chicken in the marinade and let sit 10-15 minutes.\n4. Grill or pan-fry over high heat, 3-4 minutes per side until cooked through.\n5. Slice against the grain before serving.",
        "defaultPrep": "Marinate and grill chicken strips.",
        "prepTimeMinutes": 15,
        "cookTimeMinutes": 10,
        "servings": "4"
      },
      {
        "id": "rec-black-bean-filling",
        "name": "Black bean taco filling",
        "recipeType": "component",
        "tags": ["batch-friendly", "quick", "taco"],
        "components": [
          { "id": "mc-rbb-1", "ingredientId": "ing-black-beans", "role": "protein", "quantity": "2 tins" },
          { "id": "mc-rbb-2", "ingredientId": "ing-onion", "role": "veg", "quantity": "1 medium" },
          { "id": "mc-rbb-3", "ingredientId": "ing-garlic", "role": "veg", "quantity": "2 cloves" },
          { "id": "mc-rbb-4", "ingredientId": "ing-cumin", "role": "sauce", "quantity": "1 tsp" },
          { "id": "mc-rbb-5", "ingredientId": "ing-chili-powder", "role": "sauce", "quantity": "0.5 tsp" },
          { "id": "mc-rbb-6", "ingredientId": "ing-lime", "role": "sauce", "quantity": "0.5" }
        ],
        "ingredientsText": "2 tins black beans, drained\n1 medium onion, diced\n2 cloves garlic, minced\n1 tsp cumin\n0.5 tsp chili powder\nJuice of half a lime",
        "directions": "1. Sauté diced onion in a little oil until soft, about 4 minutes.\n2. Add garlic, cumin, and chili powder; cook 1 minute.\n3. Add drained black beans and a splash of water.\n4. Mash roughly with a fork, leaving some beans whole.\n5. Cook 5 minutes until thickened. Squeeze lime juice over and stir.",
        "defaultPrep": "Sauté onion, add beans and spices, mash roughly.",
        "prepTimeMinutes": 5,
        "cookTimeMinutes": 10,
        "servings": "4"
      },
      {
        "id": "rec-yogurt-lime-sauce",
        "name": "Quick yogurt-lime sauce",
        "recipeType": "sauce",
        "tags": ["quick", "taco"],
        "components": [
          { "id": "mc-ryls-1", "ingredientId": "ing-yogurt", "role": "sauce", "quantity": "200g" },
